# Postgres connection string (Supabase, Neon, or any Postgres host).
# Use the *pooled* connection string if your provider offers one —
# important for serverless deploys on Vercel.
DATABASE_URL="postgres://user:password@host:5432/dbname"
DIRECT_URL="postgres://user:password@host:5432/dbname"

# Cloudflare R2 — find these in the Cloudflare dashboard under
# R2 > Manage R2 API Tokens.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="screenshot-archive"

# The public base URL for the bucket. Either the r2.dev URL
# (enable "Public access" on the bucket) or a custom domain you've
# mapped to it. No trailing slash.
NEXT_PUBLIC_R2_PUBLIC_BASE_URL="https://pub-xxxxxxxx.r2.dev"

# A password gating the /upload and /admin routes. Simple shared
# secret rather than full auth, since it's just you uploading.
UPLOAD_PASSWORD="choose-something-only-you-know"

# Steam
STEAM_API_KEY="steam-api-key"